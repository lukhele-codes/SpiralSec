<Window x:Class="SpiralSecGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpiralSecGUI"
        mc:Ignorable="d"
        Title="SpiralSecGUI" Height="800" Width="800">

    <Window.Resources>
        <!-- Slide Username out to the left -->
        <Storyboard x:Key="SlideOutUsername">
            <DoubleAnimation Storyboard.TargetName="UsernameTransform"
                 Storyboard.TargetProperty="X"
                 From="0" To="-800"
                 Duration="0:0:0.5"
                 AccelerationRatio="0.2"
                 DecelerationRatio="0.8"/>
        </Storyboard>

        <!-- Slide Chat in from the right -->
        <Storyboard x:Key="SlideInChat">
            <DoubleAnimation Storyboard.TargetName="ChatTransform"
                 Storyboard.TargetProperty="X"
                 From="800" To="0"
                 Duration="0:0:0.5"
                 AccelerationRatio="0.2"
                 DecelerationRatio="0.8"/>
        </Storyboard>
    </Window.Resources>
    <Grid>
        <!-- Parent Grid-->
        <!-- Logo grid (first page) -->
        <Grid x:Name="LogoGrid" Visibility="Visible">
            <Image Source="/SpiralSecFinal.png" Height="250" Width="350"/>
            <Button Content="Enter App"
                    Height="50"
                    Width="150"
                    Background="DarkGreen"
                    Foreground="White"
                    FontSize="16"
                    Click="EnterApp_Click" Margin="325,522,325,212"/>
        </Grid>


        <!-- Username grid (second page) -->
        <Grid x:Name="UsernameGrid" Visibility="Hidden">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="UsernameTransform" X="0"/>
                </Grid.RenderTransform>
                        <Label Content="Please enter your username:"
                   Height="50"
                   Margin="0,30,0,0"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   Foreground="Black"/>
            <Grid Margin="0,80,0,0">
                <TextBox x:Name="UsernameBox"
                         Width="300"
                         Height="40"/>
                <Button Content="Submit"
                        Background="DarkGreen"
                        Foreground="White"
                        Width="100"
                        Height="40"
                        Margin="320,0,0,0"
                        Click="SubmitUsername"/>
            </Grid>
        </Grid>

        <!-- Chat grid (third page) -->
        <Grid x:Name="ChatGrid" Visibility="Hidden">
            <Grid.RenderTransform>
            <TranslateTransform x:Name="ChatTransform" X="0"/>
            </Grid.RenderTransform>
            <Label x:Name="WelcomeLabel"
                   Height="50"
                   Margin="0,30,0,0"
                   FontSize="20"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Center"
                   Foreground="Black"/>
            <ListView x:Name="ChatListView"
                      Width="800"
                      Height="400"
                      Margin="0,30,0,0"
                      FontSize="14"/>
            <TextBox x:Name="QuestionBox"
                     Width="600"
                     Height="50"
                     Margin="0,450,0,0"
                     FontSize="14"
                     />
            <Button Content="Send Question"
                    Width="100"
                    Height="50"
                    Margin="620,450,0,0"
                    Background="DarkGreen"
                    Foreground="White"
                    Click="SendQuestion"/>
        </Grid>
    </Grid><!-- End of Parent Grid -->

</Window>
