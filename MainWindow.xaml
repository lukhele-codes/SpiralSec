<Window x:Class="SpiralSecGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpiralSecGUI"
        mc:Ignorable="d"
        Background="Black"
        Title="SpiralSecGUI" Height="800" Width="800">

    <Window.Resources>
        <!-- Slide Logo out to the left -->
        <Storyboard x:Key="SlideOutLogo">
            <DoubleAnimation Storyboard.TargetName="LogoTransform"
                 Storyboard.TargetProperty="X"
                 From="0" To="-800"
                 Duration="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="LogoGrid"
                 Storyboard.TargetProperty="Opacity"
                 From="1" To="0"
                 Duration="0:0:0.5"/>
        </Storyboard>

        <!-- Slide Username in from the right -->
        <Storyboard x:Key="SlideInUsername">
            <DoubleAnimation Storyboard.TargetName="UsernameTransform"
                 Storyboard.TargetProperty="X"
                 From="800" To="0"
                 Duration="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="UsernameGrid"
                 Storyboard.TargetProperty="Opacity"
                 From="0" To="1"
                 Duration="0:0:0.5"/>
        </Storyboard>

        <!-- Username slides out left and fades out-->
        <Storyboard x:Key="SlideOutUsername">
            <DoubleAnimation Storyboard.TargetName="UsernameTransform"
                 Storyboard.TargetProperty="X"
                 From="0" To="-800"
                 Duration="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="UsernameGrid"
                 Storyboard.TargetProperty="Opacity"
                 From="1" To="0"
                 Duration="0:0:0.5"/>

        </Storyboard>

        <!-- Slide Chat in from the right -->
        <Storyboard x:Key="ChatIn">
            <DoubleAnimation Storyboard.TargetName="ChatTransform"
                 Storyboard.TargetProperty="X"
                 From="800" To="0"
                 Duration="0:0:0.5"/>
            <DoubleAnimation Storyboard.TargetName="ChatGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.5"/>
        </Storyboard>

    </Window.Resources>

    <DockPanel>
        <!-- Sidebar -->
        <StackPanel DockPanel.Dock="Left" Width="200" Background="LightGray">
            <Button Content="Chatbot" Height="50" Margin="10" Click="OpenChatbot_Click"/>
            <Button Content="Task Assistant" Height="50" Margin="10" Click="OpenTaskAssistant_Click"/>
            <Button Content="Quiz" Height="50" Margin="10" Click="OpenQuiz_Click"/>
            <Button Content="Activity Log" Height="50" Margin="10" Click="OpenActivityLog_Click"/>
        </StackPanel>


        <Grid>
        <!-- Parent Grid-->
        <!-- Logo grid (first page) -->
        <Grid x:Name="LogoGrid" Visibility="Visible" Opacity="1">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="LogoTransform" X="0"/>
            </Grid.RenderTransform>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="/SPIRALFINAL.png" MaxHeight="250" MaxWidth="350" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <Button Content="Enter App"
                    Height="50"
                    Width="150"
                    Background="DarkGreen"
                    Foreground="White"
                    FontSize="16"
                    Click="EnterApp_Click" Margin="0,0,0,20"
                 />
            </StackPanel>
        </Grid>


        <!-- Username grid (second page) -->
        <Grid x:Name="UsernameGrid" Visibility="Hidden" Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="UsernameTransform" X="800"/>
            </Grid.RenderTransform>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label Content="Please enter your username:"
                   Height="50"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   Foreground="White"
                   Margin="0,0,0,20"/>
                <TextBox x:Name="UsernameBox"
                         Width="300"
                         Height="40"/>
                <Button Content="Submit"
                        Background="DarkGreen"
                        Foreground="White"
                        Width="100"
                        Height="40"
                        Margin="0,0,0,20"
                        Click="SubmitUsername"/>
            </StackPanel>

        </Grid>

        <!-- Chat grid (third page) -->
        <Grid x:Name="ChatGrid" Visibility="Hidden" Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ChatTransform" X="800"/>
            </Grid.RenderTransform>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label x:Name="WelcomeLabel" FontSize="20"
                 Foreground="White"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,20"/>


                <ScrollViewer Height="300" Width="600" Margin="0,0,0,20">
                    <ListView x:Name="ChatList"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>
                </ScrollViewer>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">


                    <TextBox x:Name="QuestionBox"
                     Width="400"
                     Height="50" 
                     FontSize="14"
                     Margin="0,0,10,0"/>


                    <Button Content="Send"
                    Width="150"
                    Height="50"
                    Background="DarkGreen"
                    Foreground="White"
                    Click="SendQuestion"/>
                </StackPanel>
            </StackPanel>


                <!-- Quiz grid (fourth page) -->
                <Grid x:Name="QuizGrid" Visibility="Hidden" Opacity="0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="QuizTransform" X="800"/>
                    </Grid.RenderTransform>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Label Content="Cybersecurity Quiz"
                   FontSize="20"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

                        <TextBlock x:Name="QuizOutput"
                       TextWrapping="Wrap"
                       Width="500"
                       Height="300"
                       Foreground="White"
                       Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Answer 1" Width="100" Margin="5" Click="Answer1_Click"/>
                            <Button Content="Answer 2" Width="100" Margin="5" Click="Answer2_Click"/>
                            <Button Content="Answer 3" Width="100" Margin="5" Click="Answer3_Click"/>
                            <Button Content="Answer 4" Width="100" Margin="5" Click="Answer4_Click"/>
                        </StackPanel>

                        <Button Content="Back to Chatbot"
                    Width="200"
                    Height="40"
                    Background="DarkGreen"
                    Foreground="White"
                    Margin="0,20,0,0"
                    Click="BackToChatbot_Click"/>
                    </StackPanel>
                    
                    
                </Grid>
    </Grid>
    <!-- End of Parent Grid -->

</Window>
