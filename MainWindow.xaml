<Window x:Class="SpiralSecGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpiralSecGUI"
        mc:Ignorable="d"
        Title="SpiralSecGUI" Height="800" Width="800">
    <Grid>
        <!--Start of Parent Grid-->
        <Grid x:Name="Logo_grid">
            <!-- Image placement -->
            <Image Source="/SpiralSecFinal.png"  Height="250" Width="250"/>

            <!-- Enter App Button -->

            <Button
         Height="50px"
         Width="200px"
         Content="Enter App"
         Margin="0,300px,0,0"
         Background="ForestGreen"
         Foreground="White"
         Click="EnterApp_Click"
         />
        </Grid>
        <!-- End of logo and enter app grid -->


        <!--Username page grid to prompt user -->

        <Grid
     x:Name="Username_grid"
    Visibility="Hidden">

            <!-- Label to instruct user-->
            <Label
     Content="Please enter your username:"
     Height="50px"
     Width="400px"
     Margin="0,0,0,10"
     FontWeight="Bold"
     Foreground="DarkBlue"
     />

            <!-- Start of username grid -->
            <!-- Textbox to prompt user -->

            <TextBox
        x:Name="Username"
        Height="50px"
        Width="400px"
     />

            <!-- Button to submit username -->
            <Button
     Height="50px"
     Width="200px"
     Margin=" 0,200px,0,0"
     Content="Submit"
     Click="SubmitName"
     />

        </Grid>
        <!-- End of username grid -->

        <!-- Start of grid for chatting/conversation phase-->
        <Grid
        x:Name="chats_grid"
            />


        <!-- Start of chat grid -->
            <!-- List view to show chats -->

            <ListView
    Height="400px"
    Width="600px"
    Margin="0,0,0,100px" 
    x:Name="ChatListView"
   />

            <!-- The Question TextBox-->
            <TextBox
    Height="50px"
    Width="200px"
    Margin="0,350px,200px,0"
    x:Name="Question"
    />

   <!-- Button to submit the question -->
    <Button
    Height="50px"
    Width="50px"
    Margin="220px,350px,0,0"
    Content="Send Question"
    Click="SendQuestion"
    />


        </Grid>

</Window>
